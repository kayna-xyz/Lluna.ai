# Copy to .env.local (never commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Auth: Ensure these are configured in the Supabase Dashboard:
#   1. Authentication > Providers > Google: enabled, with Client ID & Secret (consumer /login flow)
#   2. Authentication > Providers > Email: enabled (clinic /clinicside/auth email + password)
#   3. Authentication > URL Configuration > Redirect URLs: add your domain + /auth/callback
#      e.g. http://localhost:3000/auth/callback, http://localhost:3000/auth/callback?role=consumer

# Clinic dashboard: by default, `next dev` allows /clinicside without login.
# Production: login required unless you set CLINICSIDE_AUTH_BYPASS=true (temporary only).
# CLINICSIDE_AUTH_BYPASS=true
# CLINICSIDE_AUTH_BYPASS=false

# Optional: public URL of the consumer app (/) for QR codes & deep links. Use when advisors
# use a different host than customers (e.g. clinicside vs app subdomain).
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Azure OpenAI — required for AI features (recommend, consultant-brief, menu/parse, sales-methodology, align-final-plan)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-07-18

# [DEPRECATED] Anthropic / Claude — no longer used. Safe to remove from Vercel / local env.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# ANTHROPIC_MENU_VISION_MODEL=

# Optional: feedback email via Resend
# FEEDBACK_TO_EMAIL=owner@yourclinic.com
# FEEDBACK_FROM_EMAIL=onboarding@resend.dev
# RESEND_API_KEY=re_xxx
